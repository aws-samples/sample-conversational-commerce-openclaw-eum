# =============================================================================
# .env.example — Claw Boutique environment variable template
# =============================================================================
# Copy this file to .env and fill in all values before running deploy.sh.
#
#   cp .env.example .env
#   # Edit .env with your real values
#   ./scripts/deploy.sh --region <region> --stack-name ClawBoutiqueStack \
#     --telegram-bot-token <token> --telegram-seller-id <id> \
#     --whatsapp-phone-number-id <id> --whatsapp-waba-id <id>
#
# IMPORTANT: Never commit .env to version control. It is listed in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# AWS
# -----------------------------------------------------------------------------

# AWS region where the CDK stack will be deployed.
# Example: ap-southeast-1, us-east-1, eu-west-1
AWS_REGION=ap-southeast-1

# Your 12-digit AWS account ID.
# Find it: aws sts get-caller-identity --query Account --output text
AWS_ACCOUNT_ID=123456789012

# AWS CLI profile to use (from ~/.aws/credentials).
# Use "default" if you have only one profile configured.
AWS_PROFILE=default

# -----------------------------------------------------------------------------
# CDK Deployment
# -----------------------------------------------------------------------------

# The CloudFormation stack name created by CDK.
# Must match the stack ID in cdk/bin/app.ts (default: ClawBoutiqueStack).
CDK_STACK_NAME=ClawBoutiqueStack

# -----------------------------------------------------------------------------
# EKS Cluster (OpenClaw)
# -----------------------------------------------------------------------------

# Name of the EKS cluster where OpenClaw is deployed.
# CDK creates this cluster and deploys OpenClaw automatically.
EKS_CLUSTER_NAME=claw-boutique

# -----------------------------------------------------------------------------
# Database (Amazon RDS MySQL)
# -----------------------------------------------------------------------------

# Hostname of the RDS MySQL instance.
# Find it in the RDS console or CDK outputs after deploy.
DB_HOST=your-db-host.example.com

# MySQL port (default: 3306)
DB_PORT=3306

# MySQL username with CREATE/SELECT/INSERT/UPDATE/DELETE privileges on DB_NAME.
DB_USER=clawbot

# MySQL password for DB_USER.
DB_PASSWORD=replace_with_a_strong_password

# MySQL database name. Created automatically by deploy.sh if it does not exist.
DB_NAME=claw_boutique

# -----------------------------------------------------------------------------
# WhatsApp Business Account (End User Messaging Social)
# -----------------------------------------------------------------------------

# Meta Phone Number ID for the WhatsApp Business number registered in
# AWS End User Messaging Social.
# Find it: Meta Business Manager > WhatsApp > Phone Numbers
WHATSAPP_PHONE_NUMBER_ID=1234567890123456

# System user access token from Meta Business Manager with
# whatsapp_business_messaging permission.
WHATSAPP_TOKEN=your_meta_system_user_token

# Webhook verify token — a random string you choose.
# Used by Meta to verify your webhook endpoint during initial setup.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_random_verify_token_here

# -----------------------------------------------------------------------------
# Amazon SES (outbound transactional email)
# -----------------------------------------------------------------------------

# Verified SES sending email address. The domain must be verified in SES
# before emails can be sent in production (out of sandbox).
SES_FROM_EMAIL=orders@clawboutique.com

# Display name shown in the "From:" header of outbound emails.
SES_FROM_NAME=Claw Boutique

# -----------------------------------------------------------------------------
# Seller / Store Owner
# -----------------------------------------------------------------------------

# Seller's personal WhatsApp phone number in E.164 format.
# Receives escalation alerts and order notifications via WhatsApp.
SELLER_PHONE=+12125550101

# Seller's email address for escalation alert emails sent via SES.
SELLER_EMAIL=owner@clawboutique.com

# Seller's first name (used in email greetings and notification messages).
SELLER_NAME=Claire

# -----------------------------------------------------------------------------
# OpenClaw Gateway
# -----------------------------------------------------------------------------

# Full URL to the OpenClaw gateway exposed by the EKS NLB endpoint.
# Retrieve after deploy: kubectl get svc -n default openclaw-gateway
OPENCLAW_GATEWAY_URL=http://your-eks-nlb-endpoint:18789

# Bearer token used by the Lambda dispatcher to authenticate requests to
# the OpenClaw gateway. Generate a strong random value:
#   openssl rand -hex 32
# This token must match OPENCLAW_GATEWAY_TOKEN set in the EKS pod environment.
OPENCLAW_GATEWAY_TOKEN=replace_with_output_of_openssl_rand_hex_32
