{
  "name": "claw-boutique-dispatcher",
  "version": "1.0.0",
  "description": "Lambda dispatcher: routes SNS-wrapped WhatsApp and SES inbound email events to the OpenClaw gateway",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:deploy": "bash build.sh",
    "build:deploy-clean": "bash build.sh --clean"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "@aws-sdk/client-bedrock-agent-runtime": "^3.700.0",
    "@aws-sdk/client-socialmessaging": "^3.700.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.140",
    "@types/node": "^20.14.2",
    "typescript": "^5.4.5"
  }
}
